          </com:ComServer>
        </com:Extension>
        <desktop3:Extension Category="windows.cloudFiles">
          <desktop3:CloudFiles IconResource="Assets/SmallLogo.png">
            <desktop3:CustomStateHandler Clsid="2A69AB09-87FB-4AF7-93C4-6CA7D4853FD0" />
            <desktop3:ThumbnailProviderHandler Clsid="D2E0FD2A-1D7B-4BE4-920A-8A6D019454CB" />
