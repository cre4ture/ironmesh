        Square150x150Logo="Assets\StoreLogo.png"
        Square44x44Logo="Assets\SmallLogo.png" />
      <Extensions>
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:SurrogateServer DisplayName="Ironmesh Thumbnail Provider">
              <com:Class
                Id="D2E0FD2A-1D7B-4BE4-920A-8A6D019454CB"
