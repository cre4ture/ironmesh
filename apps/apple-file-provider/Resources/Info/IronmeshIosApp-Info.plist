<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>IronmeshIosApp</string>
    <key>CFBundleDisplayName</key>
    <string>BerryKeep</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>IronmeshConnectionInput</key>
    <string>127.0.0.1:18080</string>
    <key>IronmeshAppGroupIdentifier</key>
    <string>group.dev.ironmesh.apple.shared</string>
    <key>IronmeshKeychainAccessGroup</key>
    <string>$(AppIdentifierPrefix)dev.ironmesh.apple.shared-keychain</string>
    <key>IronmeshDomainDisplayName</key>
    <string>BerryKeep</string>
    <key>IronmeshDomainIdentifier</key>
    <string>dev.ironmesh.default</string>
    <key>NSCameraUsageDescription</key>
    <string>BerryKeep uses the camera to scan bootstrap claim QR codes during device enrollment.</string>
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
</dict>
</plist>
