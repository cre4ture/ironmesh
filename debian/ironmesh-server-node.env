# Copy this file to /etc/ironmesh/server-node.env or edit it in place, then
# enable the unit with:
#
#   sudo systemctl enable --now ironmesh-server-node.service
#
# The package does not auto-start the service because a real deployment usually
# needs site-specific bind addresses, storage paths, and TLS material.
#
# The systemd unit runs as the dedicated ironmesh-server-node system user.
# StateDirectory=ironmesh-server-node creates /var/lib/ironmesh-server-node
# with that user as owner when the service starts.

# Example:
# IRONMESH_DATA_DIR=/var/lib/ironmesh-server-node
# IRONMESH_SERVER_BIND=0.0.0.0:18080
# IRONMESH_PUBLIC_URL=https://node1.example.com
# IRONMESH_ADMIN_TOKEN=replace-me
#
# Optional plain-HTTP, loopback-only listener serving /health and
# /api/v1/cluster/status without authentication. Useful for on-device
# status displays (e.g. tiny-display-status) that run on the same host.
# Must be a loopback address (127.0.0.1 or ::1); refused otherwise.
# IRONMESH_LOCAL_STATUS_BIND=127.0.0.1:18090
#
# Increase server-node tracing when diagnosing enrollment or startup failures.
# The default is equivalent to RUST_LOG=info.
# RUST_LOG=server_node_sdk=debug,info
