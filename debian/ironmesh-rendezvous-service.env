# Copy this file to /etc/ironmesh/rendezvous-service.env or edit it in place,
# then enable the unit with:
#
#   sudo systemctl enable --now ironmesh-rendezvous-service.service
#
# The package does not auto-start the service because production deployments
# normally need explicit public URLs and TLS configuration.

# Example:
# IRONMESH_RENDEZVOUS_BIND=0.0.0.0:8443
# IRONMESH_RENDEZVOUS_PUBLIC_URL=https://rendezvous.example.com
# IRONMESH_RELAY_PUBLIC_URLS=https://rendezvous.example.com
# IRONMESH_RENDEZVOUS_PEER_URLS=https://rendezvous-b.example.com,https://rendezvous-c.example.com
# IRONMESH_RENDEZVOUS_CLIENT_CA_CERT=/etc/ironmesh/client-ca.pem
# IRONMESH_RENDEZVOUS_TLS_CERT=/etc/ironmesh/tls.crt
# IRONMESH_RENDEZVOUS_TLS_KEY=/etc/ironmesh/tls.key
#
# Set IRONMESH_RENDEZVOUS_PEER_URLS to the other public rendezvous base URLs in
# the mesh when you want /control/mesh and client discovery to advertise live
# rendezvous peers beyond the local seed URL.
