# Copy to config.env and adjust. Sourced by the supervisor and install scripts.
# config.env is git-ignored (see .gitignore in this directory) because it is
# host-local operational config, not source.

# Repository the runner serves.
REPO="cre4ture/ironmesh"

# Labels the runner advertises. The custom label is what workflows target to
# switch between GitHub-hosted and self-hosted (see ../workflow-runs-on.md).
# The reserved labels ubuntu-latest/windows-latest/macos-latest CANNOT be used
# here — GitHub forbids them on self-hosted runners.
RUNNER_LABELS="self-hosted,Linux,X64,ironmesh,ironmesh-linux"

# Container image tag built by build.sh.
IMAGE="ironmesh-runner-linux:latest"

# Command used to talk to Docker. Normally "docker". On hosts where the Docker
# socket is not group-accessible (e.g. the strictly-confined snap Docker, which
# keeps /var/run/docker.sock as root:root regardless of the docker group), set
# this to "sudo /snap/bin/docker" and grant passwordless sudo for that binary
# (see ../README.md "Bootstrap").
DOCKER_CMD="docker"

# How many concurrent ephemeral runners to keep online. Each one processes a
# single job at a time. Start with 1; raise for more parallelism.
RUNNER_COUNT=1

# Seconds to back off after an error before retrying the loop.
BACKOFF_SECONDS=10
